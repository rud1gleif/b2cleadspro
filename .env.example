# ─────────────────────────────────────────────────────────────────────────────
# B2C Leads Pro — environment variables
# Copy this file to .env and fill in your values.
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used by docker-compose to create the database on first run.
# The API reads DATABASE_URL directly.
POSTGRES_DB=b2cleads
POSTGRES_USER=b2cuser
POSTGRES_PASSWORD=change_me_in_production

# Full SQLAlchemy connection string.
# Docker Compose overrides this automatically — only set manually for local dev.
# DATABASE_URL=postgresql://b2cuser:change_me_in_production@localhost:5432/b2cleads
# For SQLite (local dev without Docker):
# DATABASE_URL=sqlite:///./b2cleads.db

# ── Redis ─────────────────────────────────────────────────────────────────────
# Docker Compose sets this automatically.
# Only override for external Redis (e.g. Redis Cloud, Upstash).
# REDIS_URL=redis://localhost:6379/0

# Queue names (defaults are fine — only change if you run multiple instances)
# REDIS_QUEUE_SCRAPE=b2c:scrape
# REDIS_QUEUE_VERIFY=b2c:verify
# REDIS_QUEUE_DISCOVERY=b2c:discovery

# ── Reacher SMTP Verifier ────────────────────────────────────────────────────
# Self-hosted Reacher — no API key required for default Docker setup.
# Docker Compose sets REACHER_URL automatically.
# Only set manually for local dev without Docker:
# REACHER_URL=http://localhost:8080

# Optional: only needed if you configured Reacher with authentication
# REACHER_API_KEY=

# Reacher SMTP identity (used in HELO/EHLO and From header during SMTP probing)
REACHER_FROM_EMAIL=verify@yourdomain.com
REACHER_HELLO_NAME=yourdomain.com

# ── Scraping defaults ─────────────────────────────────────────────────────────
DEFAULT_CONCURRENCY=5
DEFAULT_MAX_PAGES=50
REQUEST_TIMEOUT=20

# ── Application ──────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# Change this to a long random string in production!
SECRET_KEY=change-me-to-a-long-random-string-in-production
