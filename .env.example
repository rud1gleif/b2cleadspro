# ─── App ───────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=changeme-use-a-long-random-string
DEBUG=true

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=b2cleadspro
POSTGRES_USER=b2c
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://b2c:changeme@postgres:5432/b2cleadspro

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_QUEUE_DISCOVERY=queue:discovery
REDIS_QUEUE_SCRAPE=queue:scrape
REDIS_QUEUE_VERIFY=queue:verify
REDIS_QUEUE_SCORE=queue:score

# ─── Firecrawl ───────────────────────────────────────────────────────────────
FIRECRAWL_API_URL=http://firecrawl:3002
FIRECRAWL_API_KEY=

# ─── Reacher (self-hosted email verifier) ────────────────────────────────────
REACHER_URL=http://reacher:8080
REACHER_API_KEY=

# ─── Rota (proxy router) ─────────────────────────────────────────────────────
ROTA_URL=http://rota:8000
ROTA_API_KEY=

# ─── Proxy providers ─────────────────────────────────────────────────────────
# Comma-separated list of proxy URLs: http://user:pass@host:port
PROXY_DATACENTER_LIST=
PROXY_RESIDENTIAL_LIST=

# ─── Scraper ─────────────────────────────────────────────────────────────────
SCRAPER_CONCURRENCY=5
SCRAPER_DEFAULT_TIMEOUT=30
SCRAPER_RETRY_LIMIT=3
SCRAPER_DELAY_MIN=1.0
SCRAPER_DELAY_MAX=4.0

# ─── Playwright ──────────────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSER=chromium

# ─── World cities dataset ────────────────────────────────────────────────────
CITIES_DB_PATH=./data/cities.db
